@page "/"
@using Microsoft.EntityFrameworkCore
@using University.Infrastructure.Data
@inject ApplicationDbContext DbContext
@attribute [Authorize]

<PageTitle>Dashboard - University ERP</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Dashboard</MudText>
<MudText Class="mb-4">Welcome to the University ERP System</MudText>

<MudGrid>
    <MudItem xs="12" sm="6" md="3">
        <MudCard Elevation="2">
            <MudCardContent>
                <MudText Typo="Typo.body2" Color="Color.Primary">Total Students</MudText>
                <MudText Typo="Typo.h4">@_totalStudents</MudText>
                <MudText Typo="Typo.body2" Color="Color.Success">Active: @_activeStudents</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudCard Elevation="2">
            <MudCardContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Total Staff</MudText>
                <MudText Typo="Typo.h4">@_totalStaff</MudText>
                <MudText Typo="Typo.body2" Color="Color.Success">Active: @_activeStaff</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudCard Elevation="2">
            <MudCardContent>
                <MudText Typo="Typo.body2" Color="Color.Tertiary">Total Courses</MudText>
                <MudText Typo="Typo.h4">@_totalCourses</MudText>
                <MudText Typo="Typo.body2" Color="Color.Info">Active: @_activeCourses</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudCard Elevation="2">
            <MudCardContent>
                <MudText Typo="Typo.body2" Color="Color.Info">Total Revenue</MudText>
                <MudText Typo="Typo.h4">$@_totalRevenue.ToString("N0")</MudText>
                <MudText Typo="Typo.body2" Color="Color.Success">This Month</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" md="8">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Recent Enrollments</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudTable Items="@_recentEnrollments" Hover="true" Dense="true">
                    <HeaderContent>
                        <MudTh>Student</MudTh>
                        <MudTh>Course</MudTh>
                        <MudTh>Date</MudTh>
                        <MudTh>Status</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Student">@context.Student?.FirstName @context.Student?.LastName</MudTd>
                        <MudTd DataLabel="Course">@context.Course?.Name</MudTd>
                        <MudTd DataLabel="Date">@context.EnrollmentDate.ToShortDateString()</MudTd>
                        <MudTd DataLabel="Status">@context.Status</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Quick Actions</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudStack Spacing="2">
                    <AuthorizeView Roles="SuperAdmin,Admin,Faculty">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd" FullWidth="true" Href="/students/create">
                            Add New Student
                        </MudButton>
                    </AuthorizeView>
                    <MudButton Variant="Variant.Filled" Color="Color.Tertiary" StartIcon="@Icons.Material.Filled.Payment" FullWidth="true" Href="/finance/payments">
                        Record Payment
                    </MudButton>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private int _totalStudents;
    private int _activeStudents;
    private int _totalStaff;
    private int _activeStaff;
    private int _totalCourses;
    private int _activeCourses;
    private decimal _totalRevenue;
    private List<Enrollment> _recentEnrollments = new();

    protected override async Task OnInitializedAsync()
    {
        _totalStudents = await DbContext.Students.CountAsync();
        _activeStudents = await DbContext.Students.CountAsync(s => s.Status == StudentStatus.Active);
        _totalStaff = await DbContext.StaffMembers.CountAsync();
        _activeStaff = await DbContext.StaffMembers.CountAsync(s => s.Status == EmploymentStatus.Active);
        _totalCourses = await DbContext.Courses.CountAsync();
        _activeCourses = await DbContext.Courses.CountAsync(c => c.IsActive);

        var currentMonth = DateTime.UtcNow.Month;
        var currentYear = DateTime.UtcNow.Year;
        _totalRevenue = await DbContext.FeePayments
            .Where(f => f.PaymentDate.Month == currentMonth && f.PaymentDate.Year == currentYear)
            .SumAsync(f => f.Amount);

        _recentEnrollments = await DbContext.Enrollments
            .Include(e => e.Student)
            .Include(e => e.Course)
            .OrderByDescending(e => e.EnrollmentDate)
            .Take(5)
            .ToListAsync();
    }
}
