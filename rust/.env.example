# Environment variables for Rust services

# Database Configuration
UMS__DATABASE__URL=postgresql://postgres:admin123@postgres:5432/university_db
UMS__DATABASE__MAX_CONNECTIONS=10
UMS__DATABASE__MIN_CONNECTIONS=2
UMS__DATABASE__CONNECT_TIMEOUT_SECONDS=30

# Server Configuration (API only)
UMS__SERVER__HOST=0.0.0.0
UMS__SERVER__PORT=8081

# JWT Configuration
UMS__JWT__SECRET=your-super-secret-jwt-key-change-this-in-production
UMS__JWT__EXPIRATION_HOURS=24

# RabbitMQ Configuration (Workers only)
UMS__RABBITMQ__URL=amqp://guest:guest@rabbitmq:5672
UMS__RABBITMQ__EXCHANGE=ums

# Logging
RUST_LOG=info,api=debug,workers=debug,shared=debug
