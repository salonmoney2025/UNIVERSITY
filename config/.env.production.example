# ===========================================
# EBKUST University Management System
# Production Environment Configuration
# ===========================================
#
# SECURITY WARNING:
# - Never commit this file with real credentials to version control
# - Copy this file to .env.production and fill in real values
# - Use strong, randomly generated passwords in production
# - Rotate secrets regularly
#
# ===========================================

# ===========================================
# Environment
# ===========================================
NODE_ENV=production
DJANGO_ENV=production

# ===========================================
# Security & Secrets
# ===========================================
# REQUIRED: Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_THIS_TO_A_STRONG_SECRET_KEY_MIN_50_CHARACTERS_LONG

# REQUIRED: Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_JWT_SECRET_MIN_32_CHARACTERS

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,api.yourdomain.com
NEXT_PUBLIC_API_URL=https://yourdomain.com

# CORS Origins (comma-separated)
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ===========================================
# Database Configuration (PostgreSQL)
# ===========================================
POSTGRES_DB=university_lms
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Database URL for Django
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ===========================================
# Redis Configuration
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# Cache configuration
CACHE_BACKEND=django.core.cache.backends.redis.RedisCache
CACHE_LOCATION=redis://redis:6379/1

# ===========================================
# RabbitMQ Configuration
# ===========================================
RABBITMQ_USER=admin
RABBITMQ_PASS=CHANGE_THIS_TO_STRONG_PASSWORD
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST=university

# Celery configuration
CELERY_BROKER_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASS}@${RABBITMQ_HOST}:${RABBITMQ_PORT}/${RABBITMQ_VHOST}
CELERY_RESULT_BACKEND=${REDIS_URL}

# ===========================================
# Email Configuration (SMTP)
# ===========================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=your-email@yourdomain.com
EMAIL_HOST_PASSWORD=your-app-specific-password
DEFAULT_FROM_EMAIL=EBKUST University <noreply@yourdomain.com>
SERVER_EMAIL=server@yourdomain.com

# ===========================================
# SMS Configuration (Optional)
# ===========================================
SMS_PROVIDER=africas_talking
SMS_API_KEY=your-sms-api-key
SMS_USERNAME=your-sms-username
SMS_SENDER_ID=EBKUST

# ===========================================
# Payment Gateway Configuration
# ===========================================
# Flutterwave
FLUTTERWAVE_PUBLIC_KEY=your-flutterwave-public-key
FLUTTERWAVE_SECRET_KEY=your-flutterwave-secret-key
FLUTTERWAVE_ENCRYPTION_KEY=your-flutterwave-encryption-key

# PayStack (Alternative)
PAYSTACK_PUBLIC_KEY=your-paystack-public-key
PAYSTACK_SECRET_KEY=your-paystack-secret-key

# ===========================================
# Frontend Configuration (Next.js)
# ===========================================
NEXT_PUBLIC_APP_NAME=EBKUST University LMS
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_API_BASE_URL=https://yourdomain.com/api/v1

# Database URL for Next.js (SQLite for auth)
DATABASE_URL=file:./prisma/dev.db

# ===========================================
# File Upload & Storage
# ===========================================
# Maximum file upload size (in MB)
MAX_UPLOAD_SIZE=10

# AWS S3 (Optional - for production file storage)
USE_S3=false
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=ebkust-university-files
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=${AWS_STORAGE_BUCKET_NAME}.s3.amazonaws.com

# ===========================================
# Logging & Monitoring
# ===========================================
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO
RUST_LOG=api=info,shared=info,sqlx=warn

# Sentry (Error Tracking - Optional)
SENTRY_DSN=your-sentry-dsn
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ===========================================
# Performance & Scalability
# ===========================================
# Django settings
DJANGO_DEBUG=False
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True

# Database connection pooling
DB_CONN_MAX_AGE=600

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ===========================================
# Backup Configuration
# ===========================================
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=ebkust-university-backups

# ===========================================
# Feature Flags
# ===========================================
ENABLE_REGISTRATION=true
ENABLE_PASSWORD_RESET=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_SMS_NOTIFICATIONS=true
ENABLE_PAYMENT_GATEWAY=true

# ===========================================
# Admin Configuration
# ===========================================
DJANGO_SUPERUSER_EMAIL=admin@yourdomain.com
DJANGO_SUPERUSER_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD
DJANGO_SUPERUSER_FIRST_NAME=System
DJANGO_SUPERUSER_LAST_NAME=Administrator

# ===========================================
# Session & Security
# ===========================================
SESSION_COOKIE_AGE=86400
SESSION_SAVE_EVERY_REQUEST=false
SESSION_ENGINE=django.contrib.sessions.backends.cache
SESSION_CACHE_ALIAS=default

# CSRF Protection
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ===========================================
# Timezone & Localization
# ===========================================
TZ=Africa/Freetown
LANGUAGE_CODE=en-us
TIME_ZONE=Africa/Freetown
USE_TZ=true

# ===========================================
# Application Specific Settings
# ===========================================
# Academic year settings
CURRENT_ACADEMIC_YEAR=2024/2025
CURRENT_SEMESTER=1

# Institution details
INSTITUTION_NAME=Ernest Bai Koroma University of Science and Technology
INSTITUTION_SHORT_NAME=EBKUST
INSTITUTION_EMAIL=info@ebkustsl.edu.sl
INSTITUTION_PHONE=+232-XX-XXXXXX
INSTITUTION_ADDRESS=Makeni, Sierra Leone
