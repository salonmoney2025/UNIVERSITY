# =============================================
# UNIVERSITY LMS ENVIRONMENT CONFIGURATION
# =============================================
# Copy this file to .env and update with your values

# =============================================
# DATABASE CONFIGURATION
# =============================================
POSTGRES_DB=university_lms
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://postgres:your_secure_password_here@postgres:5432/university_lms

# =============================================
# DJANGO CONFIGURATION
# =============================================
SECRET_KEY=your_django_secret_key_generate_new_one
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DJANGO_SETTINGS_MODULE=config.settings.development

# =============================================
# REDIS CONFIGURATION
# =============================================
REDIS_URL=redis://redis:6379/0
CACHE_TTL=300

# =============================================
# CELERY CONFIGURATION
# =============================================
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/1

# =============================================
# RABBITMQ CONFIGURATION
# =============================================
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# =============================================
# EMAIL CONFIGURATION
# =============================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=noreply@university-lms.com

# =============================================
# SMS CONFIGURATION (Choose one)
# =============================================
# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Africa's Talking
AFRICAS_TALKING_USERNAME=your_username
AFRICAS_TALKING_API_KEY=your_api_key
AFRICAS_TALKING_SHORTCODE=your_shortcode

# =============================================
# PAYMENT GATEWAY CONFIGURATION
# =============================================
# Stripe (International)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# PayPal (International)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox  # or 'live' for production

# Flutterwave (African Mobile Money)
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-your_public_key
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your_secret_key
FLUTTERWAVE_ENCRYPTION_KEY=your_encryption_key

# Paystack (African Mobile Money)
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key

# Mock Payment (Development/Testing)
ENABLE_MOCK_PAYMENT=True

# =============================================
# FILE STORAGE CONFIGURATION
# =============================================
# Local Storage (Development)
MEDIA_ROOT=/app/media
STATIC_ROOT=/app/staticfiles

# AWS S3 (Production - Optional)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_STORAGE_BUCKET_NAME=your_bucket_name
AWS_S3_REGION_NAME=us-east-1
USE_S3=False

# =============================================
# FRONTEND CONFIGURATION
# =============================================
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_APP_NAME=University LMS
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================
# SECURITY CONFIGURATION
# =============================================
# JWT Settings
JWT_SECRET_KEY=your_jwt_secret_key_different_from_django_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_LIFETIME=60  # minutes
JWT_REFRESH_TOKEN_LIFETIME=1440  # minutes (24 hours)

# Session Settings
SESSION_COOKIE_SECURE=False  # Set to True in production (HTTPS)
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SECURE=False  # Set to True in production (HTTPS)

# Password Reset
PASSWORD_RESET_TIMEOUT=3600  # seconds (1 hour)

# =============================================
# LOGGING CONFIGURATION
# =============================================
LOG_LEVEL=INFO
LOG_FILE=/app/logs/university.log

# =============================================
# ANALYTICS & MONITORING (Optional)
# =============================================
SENTRY_DSN=your_sentry_dsn
GOOGLE_ANALYTICS_ID=UA-XXXXX-Y

# =============================================
# DEVELOPMENT/TESTING FLAGS
# =============================================
ENABLE_DEBUG_TOOLBAR=True
ENABLE_SILK_PROFILING=False
RUN_MIGRATIONS_ON_STARTUP=True
CREATE_SUPERUSER_ON_STARTUP=False

# =============================================
# SUPERUSER CONFIGURATION (Development Only)
# =============================================
DJANGO_SUPERUSER_EMAIL=admin@university-lms.com
DJANGO_SUPERUSER_PASSWORD=Admin@123!
DJANGO_SUPERUSER_FIRST_NAME=Super
DJANGO_SUPERUSER_LAST_NAME=Admin

# =============================================
# UNIVERSITY CONFIGURATION
# =============================================
UNIVERSITY_NAME=University of Excellence
UNIVERSITY_SHORTNAME=UOE
UNIVERSITY_TIMEZONE=Africa/Lagos
UNIVERSITY_CURRENCY=NGN
UNIVERSITY_CURRENCY_SYMBOL=₦

# =============================================
# FEATURE FLAGS
# =============================================
ENABLE_STUDENT_PORTAL=True
ENABLE_STAFF_PORTAL=True
ENABLE_PARENT_PORTAL=True
ENABLE_MOBILE_MONEY=True
ENABLE_LIBRARY_MODULE=True
ENABLE_HOSTEL_MODULE=True
ENABLE_SMS_NOTIFICATIONS=True
ENABLE_EMAIL_NOTIFICATIONS=True
